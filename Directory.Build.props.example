<Project>
  <PropertyGroup>
    <!-- MegaDot / Godot 4.5.1 mono executable used for export-pack when publishing. -->
    <GodotPath>C:/megadot/MegaDot_v4.5.1-stable_mono_win64.exe</GodotPath>

    <!-- Optional override. The template can usually discover the default Windows Steam path. -->
    <Sts2Path>C:/Program Files (x86)/Steam/steamapps/common/Slay the Spire 2</Sts2Path>
  </PropertyGroup>
</Project>
